# ===============================
# ENVIRONMENT VARIABLES TEMPLATE
# ===============================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Spring Profile (dev, staging, prod)
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/resort_auth?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# JWT Configuration (CRITICAL: Use strong random keys in production)
# Generate with: openssl rand -base64 64
JWT_SECRET=your-256-bit-secret-key-here-minimum-32-characters-required-use-strong-random-generator
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# Password Reset
PASSWORD_RESET_EXPIRATION_MS=900000

# Rate Limiting
RATE_LIMIT_CAPACITY=5
RATE_LIMIT_TOKENS=5
RATE_LIMIT_MINUTES=1

# Account Lockout
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Server Configuration
SERVER_PORT=8081

# Email Configuration (for password reset - to be implemented)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
